{
  "name": "setup-msstore-cli",
  "version": "0.4.0",
  "private": true,
  "description": "Setup Microsoft Store Developer CLI GitHub Action",
  "main": "lib/src/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "copy-license": "copy setup-msstore-cli-task/licenses.txt licenses.txt || cp setup-msstore-cli-task/licenses.txt licenses.txt",
    "create-tfx": "npm run copy-license && tfx extension create --manifest-globs vss-extension.json",
    "package": "node build.mjs && npm run create-tfx",
    "test": "jest --detectOpenHandles",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/setup-msstore-cli.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "msstore-cli"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "azure-pipelines-task-lib": "^5.277.0",
    "azure-pipelines-tool-lib": "^2.0.12",
    "fs-extra": "^11.3.6"
  },
  "overrides": {
    "azure-pipelines-task-lib": "^5.277.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-jest": "^30.4.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "prettier": "3.9.5",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3"
  }
}
